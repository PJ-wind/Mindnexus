# ============================================
# MINDNEXUS ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in
# ============================================

# Database (from Railway — copy the PostgreSQL URL)
DATABASE_URL="postgresql://postgres:HVTQrvErarMroVgWXmKWJNRvJEjdADOK@postgres.railway.internal:5432/railway"

# NextAuth (generate a secret: run `openssl rand -base64 32` in terminal)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Anthropic Claude API (from console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# App settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MindNexus"

# Email (optional - for sending reminders)
# Get free SMTP from Gmail or Mailtrap
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="MindNexus <noreply@mindnexus.ng>"
